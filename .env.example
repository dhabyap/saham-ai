# ============================================
# AI Stock Analyzer Indonesia - Configuration
# ============================================

# Telegram Bot (required for Telegram features)
# Get token from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# AI Provider (openai, gemini, ollama, openrouter, or groq)
AI_PROVIDER=openai

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Google Gemini API Key (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local LLM, required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenRouter (OpenAI-compatible, required if AI_PROVIDER=openrouter)
# Get key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional: for OpenRouter rankings
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=AI Stock Analyzer

# Groq (fast inference, free tier available, required if AI_PROVIDER=groq)
# Get key from: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Database
DATABASE_PATH=app/database/stock.db

# Scheduler interval in minutes
SCHEDULER_INTERVAL=15

# AI Learning defaults
MIN_CONFIDENCE_THRESHOLD=50
DEFAULT_RISK_LEVEL=moderate
DEFAULT_STRATEGY=swing

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Chart directory
CHART_DIR=app/static/charts
