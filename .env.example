# ============================================
# AI Stock Analyzer Indonesia - Configuration
# ============================================

# Telegram Bot (required for Telegram features)
# Get token from: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# AI Provider (openai, gemini, or ollama)
AI_PROVIDER=openai

# OpenAI API Key (required if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# Google Gemini API Key (required if AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local LLM, required if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Database
DATABASE_PATH=app/database/stock.db

# Scheduler interval in minutes
SCHEDULER_INTERVAL=15

# AI Learning defaults
MIN_CONFIDENCE_THRESHOLD=50
DEFAULT_RISK_LEVEL=moderate
DEFAULT_STRATEGY=swing

# Server
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Chart directory
CHART_DIR=app/static/charts
