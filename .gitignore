# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local environment and secrets
.env
.env.*
!.env.example

# Runtime data
*.db
*.sqlite
*.sqlite3
app/database/*.db
*.session

# Generated charts
app/static/charts/
!app/static/charts/.gitkeep

# Logs and temporary files
*.log
logs/
!logs/.gitkeep
tmp/
temp/
.tmp-*/
nul

# OS and editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.stackdump

# Upload folders
uploads/
!uploads/.gitkeep

# Generated / export files
telegram_session_string.txt
market_reports.json
market_reports_*.json
backtest_results*.json

# Local config — not portable
config/settings.json

# Standalone analysis/backtest scripts — kept for reference but not in VCS
backtest_bpjs.py
market_report_analysis.py
market_report_scraper.py
credentials.json
_x.py
*.bak
a.txt
b.txt
